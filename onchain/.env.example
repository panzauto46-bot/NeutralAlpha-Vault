SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
NEUTRALALPHA_VAULT_PROGRAM_ID=<deployed_program_id>
DRIFT_PROGRAM_ID=<drift_program_id>
PYTH_PRICE_FEED=<pyth_price_feed_pubkey>
HARNESS_FLOW_MODE=vault
HARNESS_STRICT=1

# Example account metas for each step. Replace with real account schema.
NEUTRALALPHA_DEPOSIT_ACCOUNTS_JSON=[{"pubkey":"$PAYER","isSigner":true,"isWritable":true}]
NEUTRALALPHA_HEDGE_ACCOUNTS_JSON=[{"pubkey":"$PAYER","isSigner":true,"isWritable":true}]
NEUTRALALPHA_UNWIND_ACCOUNTS_JSON=[{"pubkey":"$PAYER","isSigner":true,"isWritable":true}]
